# 服务器配置
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_MODE=release
SERVER_RATE_LIMIT=100
SERVER_RATE_BURST=200
JWT_SECRET=your_jwt_secret_here

# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=litecms
DB_SSLMODE=disable
DB_MAX_OPEN_CONNS=10
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=1800
DB_CONN_MAX_IDLE_TIME=300

# 缓存配置
CACHE_ENABLED=true
CACHE_MAX_COST=52428800
CACHE_NUM_COUNTERS=100000
CACHE_BUFFER_ITEMS=64
CACHE_TTL=300

# 存储配置
STORAGE_UPLOAD_PATH=./static/uploads
STORAGE_MAX_SIZE=5242880
